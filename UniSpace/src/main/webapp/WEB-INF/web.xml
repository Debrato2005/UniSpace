<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>UniSpace - Classroom Booking System</display-name>

    <!-- Default page when app loads -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- ============================================================
         NOTE: Since all Servlets use @WebServlet annotations,
         you do NOT need to declare them here manually.
         Tomcat reads the @WebServlet("/LoginServlet") annotation
         directly from the class and registers the URL mapping
         automatically.

         This web.xml only needs to exist and declare the welcome
         file. The session timeout below is optional but recommended.
    ============================================================ -->

    <!-- Session timeout: 30 minutes of inactivity logs the user out -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>